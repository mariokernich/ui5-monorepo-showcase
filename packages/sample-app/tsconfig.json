{
	"compilerOptions": {
		"target": "es2023",
		"module": "es2022",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"allowJs": true,
		"strict": true,
		"strictNullChecks": false,
		"strictPropertyInitialization": false,
		"types": ["@openui5/types", "@types/qunit"],
		"paths": {
			"com/myorg/myapp/*": ["./webapp/*"],
			"com/myorg/mylib/*": ["../sample-lib/src/com/myorg/mylib/*"],
			"unit/*": ["./webapp/test/unit/*"],
			"integration/*": ["./webapp/test/integration/*"]
		}
	},
	"exclude": ["./webapp/test/e2e/**/*"],
	"include": ["./webapp/**/*", "../sample-lib/src/**/*.gen.d.ts"]
}
