{
  "name": "com.myorg.mylib",
  "version": "1.0.0",
  "description": "UI5 Library: com.myorg.mylib",
  "author": "Mario Kernich",
  "license": "Apache-2.0",
  "types": "dist/index.d.ts",
  "files": [
    ".eslintrc.js",
    "LICENCE",
    "README.md",
    "tsconfig.json",
    "ui5.yaml",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "src",
    "test"
  ],
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "ui5 build --clean-dest",
    "build:ts-interfaces": "npx @ui5/ts-interface-generator",
    "start": "ui5 serve --port 8081",
    "start:dist": "npm start -- --config ui5-dist.yaml",
    "testsuite": "ui5 serve -o test-resources/com/myorg/mylib/qunit/testsuite.qunit.html",
    "ts-typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "karma": "karma start",
    "karma-ci": "karma start karma-ci.conf.js",
    "karma-ci-cov": "karma start karma-ci-cov.conf.js",
    "test": "npm run lint && npm run karma-ci-cov"
  },
  "devDependencies": {
    "@openui5/types": "1.150.0",
    "@types/jquery": "^4.0.1",
    "@types/qunit": "^2.19.14",
    "@ui5/cli": "^4.0.57",
    "@ui5/ts-interface-generator": "^0.11.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-ui5": "^4.1.0",
    "karma-ui5-transpile": "^3.6.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "ui5-middleware-livereload": "^3.3.1",
    "ui5-tooling-transpile": "^3.11.3"
  }
}
